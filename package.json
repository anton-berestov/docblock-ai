{
	"name": "docblock-ai",
	"displayName": "DocBlock AI",
	"description": "Generate documentation comments for any programming language using OpenAI GPT or GitHub Copilot. Supports PHP, JS, TS, Python, Java, C#, Go, Ruby, Rust.",
	"version": "1.0.0",
	"publisher": "AntonBerestov",
	"icon": "icon.png",
	"keywords": [
		"documentation",
		"docblock",
		"phpdoc",
		"jsdoc",
		"docstring",
		"openai",
		"copilot",
		"ai",
		"php",
		"python",
		"javascript",
		"typescript"
	],
	"categories": [
		"Programming Languages",
		"Snippets",
		"Other"
	],
	"engines": {
		"vscode": "^1.90.0"
	},
	"main": "./extension.js",
	"contributes": {
		"configuration": {
			"title": "DocBlock AI",
			"properties": {
				"docblock-ai.provider": {
					"type": "string",
					"default": "openai",
					"enum": [
						"openai",
						"copilot"
					],
					"enumDescriptions": [
						"Use OpenAI API (requires API key)",
						"Use GitHub Copilot (requires Copilot subscription)"
					],
					"description": "AI provider for documentation generation"
				},
				"docblock-ai.openaiApiKey": {
					"type": "string",
					"default": "",
					"description": "Your OpenAI API key (required when provider is OpenAI)"
				},
				"docblock-ai.model": {
					"type": "string",
					"default": "gpt-3.5-turbo",
					"enum": [
						"gpt-3.5-turbo",
						"gpt-4",
						"gpt-4-turbo",
						"gpt-4o"
					],
					"description": "OpenAI model to use (when provider is OpenAI)"
				},
				"docblock-ai.language": {
					"type": "string",
					"default": "English",
					"enum": [
						"English",
						"Russian",
						"Spanish",
						"Italian",
						"French",
						"German",
						"Portuguese",
						"Polish",
						"Chinese",
						"Japanese"
					],
					"enumDescriptions": [
						"English",
						"Russian (Русский)",
						"Spanish (Español)",
						"Italian (Italiano)",
						"French (Français)",
						"German (Deutsch)",
						"Portuguese (Português)",
						"Polish (Polski)",
						"Chinese (中文)",
						"Japanese (日本語)"
					],
					"description": "Language for generated documentation text"
				}
			}
		},
		"commands": [
			{
				"command": "docblock-ai.generateDoc",
				"title": "DocBlock AI: Generate Documentation"
			},
			{
				"command": "docblock-ai.insertApiKey",
				"title": "DocBlock AI: Set OpenAI API Key"
			}
		],
		"menus": {
			"editor/context": [
				{
					"command": "docblock-ai.generateDoc",
					"when": "editorHasSelection && (editorLangId == php || editorLangId == javascript || editorLangId == typescript || editorLangId == python || editorLangId == java || editorLangId == csharp || editorLangId == go || editorLangId == ruby || editorLangId == rust)",
					"group": "1_modification"
				}
			]
		}
	},
	"scripts": {
		"lint": "eslint .",
		"pretest": "npm run lint",
		"test": "vscode-test"
	},
	"devDependencies": {
		"@types/mocha": "^10.0.6",
		"@types/node": "18.x",
		"@types/vscode": "^1.90.0",
		"@vscode/test-cli": "^0.0.4",
		"@vscode/test-electron": "^2.3.8",
		"eslint": "^8.54.0",
		"typescript": "^5.3.2"
	},
	"dependencies": {
		"openai": "^4.20.1"
	}
}
